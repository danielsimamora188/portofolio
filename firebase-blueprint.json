{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project in Daniel Tulus's portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["web", "photography", "design", "certificate"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "buttonLink": { "type": "string" },
        "detailText": { "type": "string" },
        "specs": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "category", "description"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "An inquiry message received from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "message", "status", "createdAt"]
    },
    "Experience": {
      "title": "Experience",
      "description": "A dynamic work experience entry.",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "location": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "details": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["company", "location", "role", "period", "description"]
    },
    "Biodata": {
      "title": "Biodata",
      "description": "User's biographical and contact links.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "shortName": { "type": "string" },
        "title": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "whatsappLink": { "type": "string" },
        "instagram": { "type": "string" },
        "instagramLink": { "type": "string" },
        "linkedin": { "type": "string" },
        "githubCV": { "type": "string" },
        "cvFilename": { "type": "string" },
        "aboutMe": { "type": "string" },
        "experienceYears": { "type": "string" },
        "projectsCompletedCount": { "type": "string" },
        "supportAvailability": { "type": "string" }
      },
      "required": ["fullName", "shortName", "title", "email"]
    },
    "Service": {
      "title": "Service",
      "description": "A dynamic service offering.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "checklist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "order": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "description", "icon", "checklist"]
    },
    "SkillCategory": {
      "title": "SkillCategory",
      "description": "A category of dynamic skills.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "level": { "type": "string" }
            },
            "required": ["name"]
          }
        },
        "order": { "type": "number" }
      },
      "required": ["title", "skills"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "List of dynamic portfolio project cards."
    },
    "/contacts/{messageId}": {
      "schema": "ContactMessage",
      "description": "Inbox contact messages submitted by prospective clients."
    },
    "/experiences/{experienceId}": {
      "schema": "Experience",
      "description": "Work experiences listed on the services page."
    },
    "/biodata/{docId}": {
      "schema": "Biodata",
      "description": "Biological data stored under personal-bio."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Services listed under offerings."
    },
    "/skills/{skillCategoryId}": {
      "schema": "SkillCategory",
      "description": "Detailed skill lists per category/field."
    }
  }
}
